<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>Bautizo | Sofía Valentina</title>
    <meta property="og:title" content="¡Estás invitado al Bautizo de Sofía Valentina!">
    <meta property="og:description" content="Acompáñanos este 24 de Octubre de 2026. Haz clic para ver los detalles.">
    <meta property="og:image" content="https://www.dropbox.com/scl/fi/9avggx6ox57b9tkq9enxc/bautizo1.png?rlkey=xe50yu0f36p6uixsddj7mqs25&raw=1">
    <meta property="og:type" content="website">
    <link rel="apple-touch-icon" href="https://www.dropbox.com/scl/fi/9avggx6ox57b9tkq9enxc/bautizo1.png?rlkey=xe50yu0f36p6uixsddj7mqs25&raw=1">

    <script>
        const CONFIG = {
            fecha_countdown: "Oct 24, 2026 12:00:00", 
            fecha_texto_largo: "Sábado, 24 de Octubre de 2026",
            nombre_bebe: "Sofía Valentina",
            frase_biblica: "En tus manos, Señor, pongo mi vida y mi camino.",
            texto_invitacion: "Queremos compartir la alegría del bautizo de nuestra pequeña. Tu presencia es nuestro mejor regalo.",
            papas: "Roberto & Lucía",
            padrinos: "Carlos & Elena",
            iglesia_nombre: "Parroquia de San Juan Bautista",
            iglesia_hora: "12:00 PM",
            salon_nombre: "Quinta Las Palmas",
            salon_hora: "02:30 PM",
            iti_titulo: "Nuestro Itinerario",
            iti_1: "12:00 PM - Ceremonia Religiosa",
            iti_2: "02:30 PM - Recepción y Comida",
            iti_3: "04:30 PM - Pastel y Mesa de Dulces",
            vest_titulo: "Código de Vestimenta",
            vest_tipo: "Formal / Guayabera",
            vest_nota: "Sugerencia: Colores claros o pasteles",
            sobres_titulo: "Lluvia de Sobres",
            sobres_texto: "Su presencia es nuestro mayor regalo, pero si desean tener un detalle, contaremos con un buzón para sobres en la recepción.",
            mapa_iglesia: "https://maps.google.com",
            mapa_salon: "https://maps.google.com",
            link_hospedaje: "https://migrandia.github.io/hotel-bautizo/",
            link_regalos: "https://mesaderegalos.liverpool.com.mx/",
            whatsapp_confirmar: "https://wa.me/521234567890?text=Confirmo%20asistencia",
            link_musica: "https://www.dropbox.com/scl/fi/80hypdxkg24wx6x7oael2/En-Tus-Manos-Se-or.mp3?rlkey=j4di62c9sgj4txgwbpikcngp3&raw=1",
            foto_1: "https://www.dropbox.com/scl/fi/9avggx6ox57b9tkq9enxc/bautizo1.png?rlkey=xe50yu0f36p6uixsddj7mqs25&raw=1",
            foto_2: "https://www.dropbox.com/scl/fi/amq1vsm698rsf1daimlr6/bautizo2.png?rlkey=z2d7is02ys38pl6rd85cbmorz&raw=1",
            foto_3: "https://www.dropbox.com/scl/fi/tlg7mvb8lfoe4tmvuhooo/bautizo31.jpg?rlkey=2b1tqc59dp9law24w9wpfav6n&raw=1",
            foto_4: "https://www.dropbox.com/scl/fi/19bv17jgagbs4sd6k7wxe/bautizo41.jpg?rlkey=nogetjdj9gxp8tyqo76gev7ex&raw=1",
            color_primario: "#d4b483", 
            color_texto: "#2d2d2d",    
            color_fondo_seccion: "#fdfaf8",
            fuente_elegante: "'Cormorant Garamond', serif",
            fuente_moderna: "'Montserrat', sans-serif"
        };
    </script>

    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;1,400&family=Montserrat:wght@200;400;700&display=swap" rel="stylesheet">
    
    <style>
        :root { --oro: #d4b483; --texto: #2d2d2d; --bloque: #fdfaf8; --fuente-e: 'Cormorant Garamond', serif; --fuente-m: 'Montserrat', sans-serif; }
        body, html { margin: 0; padding: 0; background-color: #1a1a1a; color: var(--texto); font-family: var(--fuente-m); overflow-x: hidden; text-align: center; scroll-behavior: smooth;}
        
        .invitation-container { max-width: 480px; margin: 0 auto; background-color: #fff; box-shadow: 0 0 50px rgba(0,0,0,0.5); }
        
        /* AJUSTE PARA QUE LA FOTO NO SE CORTE */
        .parallax { 
            width: 100%;
            height: 80vh; 
            background-attachment: fixed; 
            background-position: center; 
            background-size: cover; 
            background-repeat: no-repeat;
            position: relative; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
        }

        /* Corrección específica para escritorio */
        @media (min-width: 768px) {
            .parallax { background-attachment: scroll; height: 600px; }
        }

        #img-1::after { content: ""; position: absolute; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.3); z-index: 1; }
        
        h1.nombre-portada { font-family: var(--fuente-e); font-size: 3.5rem; color: white; z-index: 2; text-shadow: 0 2px 15px rgba(0,0,0,0.5); margin: 0; font-weight: 300; }
        .bautizo-txt { font-size: 0.8rem; letter-spacing: 6px; color: white; z-index: 2; margin-bottom: 10px; font-weight: bold; }

        section { padding: 60px 20px; background: white; }
        h2.seccion { font-family: var(--fuente-e); font-size: 2.2rem; color: var(--texto); margin-bottom: 20px; font-weight: 600;}
        
        .details-box { background: var(--bloque); padding: 30px 20px; border-radius: 15px; border: 1px solid #eee; margin: 15px 0; }
        
        .countdown-container { display: flex; justify-content: center; gap: 15px; margin-top: 20px; }
        .count-item { background: white; border: 1px solid var(--oro); border-radius: 10px; padding: 10px; min-width: 60px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        .count-num { display: block; font-size: 1.5rem; font-weight: bold; color: var(--oro); font-family: var(--fuente-e); }
        .count-lab { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 1px; color: #888; }

        .btn-menu { display: block; padding: 15px 5px; border: 1px solid var(--oro); color: var(--oro); text-decoration: none; font-weight: bold; font-size: 0.7rem; letter-spacing: 2px; border-radius: 30px; text-transform: uppercase; margin: 10px auto; width: 80%; transition: 0.3s; }
        .btn-confirm { background: var(--oro); color: white; width: 85%; margin: 30px auto; padding: 20px; display: block; text-decoration: none; border-radius: 40px; font-weight: bold; letter-spacing: 2px; box-shadow: 0 4px 15px rgba(212,180,131,0.4); }

        #music-btn { position: fixed; bottom: 20px; right: 20px; z-index: 1000; width: 50px; height: 50px; background: var(--oro); border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 2px solid white; cursor: pointer; }
        
        .img-final { width: 100%; height: auto; display: block; margin-bottom: 20px; }
    </style>
</head>
<body>

    <div id="music-btn" onclick="controlMusica()">
        <svg id="play-svg" width="24" fill="white" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        <svg id="pause-svg" width="24" fill="white" viewBox="0 0 24 24" style="display:none;"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
    </div>
    <audio id="track" loop><source id="audio-src" src="" type="audio/mpeg"></audio>

    <div class="invitation-container">
        
        <div id="img-1" class="parallax">
            <div style="z-index: 2;">
                <p class="bautizo-txt">MI BAUTIZO</p>
                <h1 id="baby-name" class="nombre-portada"></h1>
            </div>
        </div>

        <section>
            <span style="font-size: 2.5rem; color: var(--oro);">†</span>
            <p id="frase" style="font-family: var(--fuente-e); font-style: italic; font-size: 1.5rem; color: #555;"></p>
            
            <div style="margin-top: 40px;">
                <p style="font-size: 0.8rem; letter-spacing: 3px; color: var(--oro); font-weight: bold; margin-bottom: 5px;">ACOMPÁÑANOS EL</p>
                <h2 id="txt-fecha-larga" style="font-family: var(--fuente-e); font-size: 1.6rem; margin: 10px 0;"></h2>
                <div class="countdown-container">
                    <div class="count-item"><span id="days" class="count-num">00</span><span class="count-lab">Días</span></div>
                    <div class="count-item"><span id="hours" class="count-num">00</span><span class="count-lab">Hrs</span></div>
                    <div class="count-item"><span id="minutes" class="count-num">00</span><span class="count-lab">Min</span></div>
                    <div class="count-item"><span id="seconds" class="count-num">00</span><span class="count-lab">Seg</span></div>
                </div>
            </div>
        </section>

        <div id="img-2" class="parallax"></div>

        <section style="background: var(--bloque);">
            <h2 class="seccion">Nuestra Familia</h2>
            <p style="font-size: 0.7rem; letter-spacing: 2px; color: #888;">MIS PADRES</p>
            <p id="p-names" style="font-size: 1.3rem; margin-top: 5px;"></p>
            <div class="padrinos-box" style="background: white; padding: 20px; border-radius: 10px; margin-top: 20px;">
                <p style="font-size: 0.7rem; letter-spacing: 2px; color: var(--oro); font-weight: bold; margin: 0;">MIS PADRINOS</p>
                <p id="g-names" style="font-size: 1.5rem; font-family: var(--fuente-e); font-weight: 600; margin-top: 10px;"></p>
            </div>
        </section>

        <div id="img-3" class="parallax"></div>

        <section>
            <h2 class="seccion">¿Dónde y Cuándo?</h2>
            <div class="details-box">
                <p style="color: var(--oro); font-weight: bold; letter-spacing: 2px;">⛪ CEREMONIA</p>
                <p id="iglesia" style="font-weight: bold; margin-top: 10px;"></p>
                <p id="hora-i" style="font-size: 1.8rem; font-family: var(--fuente-e); color: var(--oro); margin: 5px 0; font-weight: bold;"></p>
                <a id="mapa-i" href="#" target="_blank" class="btn-menu">VER UBICACIÓN</a>
            </div>
            <div class="details-box">
                <p style="color: var(--oro); font-weight: bold; letter-spacing: 2px;">🎉 RECEPCIÓN</p>
                <p id="salon" style="font-weight: bold; margin-top: 10px;"></p>
                <p id="hora-s" style="font-size: 1.8rem; font-family: var(--fuente-e); color: var(--oro); margin: 5px 0; font-weight: bold;"></p>
                <a id="mapa-s" href="#" target="_blank" class="btn-menu">VER UBICACIÓN</a>
            </div>
        </section>

        <div id="img-4" class="parallax"></div>

        <section style="padding-bottom: 0;">
            <h2 class="seccion">Te Esperamos</h2>
            <p style="font-size: 0.9rem; line-height: 1.6; color: #555; max-width: 90%; margin: 0 auto 30px;">
                Su presencia es nuestro mayor regalo, pero si desean tener un detalle, contaremos con una mesa de regalos o lluvia de sobres.
            </p>
            <img id="ultima-foto" src="" class="img-final" alt="Sofía Valentina">
        </section>

        <section>
            <div style="display: flex; justify-content: center; gap: 10px; flex-wrap: wrap;">
                <a id="btn-hotel" href="#" target="_blank" class="btn-menu" style="width: 42%;">🏨 HOSPEDAJE</a>
                <a id="btn-gifts" href="#" target="_blank" class="btn-menu" style="width: 42%;">🎁 REGALOS</a>
            </div>
            <a id="btn-wa" href="#" target="_blank" class="btn-confirm">📲 CONFIRMAR ASISTENCIA</a>
            <p id="footer-name" style="margin-top: 50px; font-family: var(--fuente-e); font-size: 2.2rem; color: var(--oro);"></p>
        </section>
    </div>

    <script>
        // CARGAR CONFIGURACIÓN
        const r = document.documentElement.style;
        r.setProperty('--oro', CONFIG.color_primario);
        r.setProperty('--texto', CONFIG.color_texto);
        r.setProperty('--bloque', CONFIG.color_fondo_seccion);
        r.setProperty('--fuente-e', CONFIG.fuente_elegante);
        r.setProperty('--fuente-m', CONFIG.fuente_moderna);

        document.getElementById('baby-name').innerText = CONFIG.nombre_bebe;
        document.getElementById('footer-name').innerText = CONFIG.nombre_bebe;
        document.getElementById('frase').innerText = CONFIG.frase_biblica;
        document.getElementById('txt-fecha-larga').innerText = CONFIG.fecha_texto_largo;
        document.getElementById('p-names').innerText = CONFIG.papas;
        document.getElementById('g-names').innerText = CONFIG.padrinos;
        document.getElementById('iglesia').innerText = CONFIG.iglesia_nombre;
        document.getElementById('hora-i').innerText = CONFIG.iglesia_hora;
        document.getElementById('salon').innerText = CONFIG.salon_nombre;
        document.getElementById('hora-s').innerText = CONFIG.salon_hora;
        document.getElementById('mapa-i').href = CONFIG.mapa_iglesia;
        document.getElementById('mapa-s').href = CONFIG.mapa_salon;
        document.getElementById('btn-hotel').href = CONFIG.link_hospedaje;
        document.getElementById('btn-gifts').href = CONFIG.link_regalos;
        document.getElementById('btn-wa').href = CONFIG.whatsapp_confirmar;
        document.getElementById('audio-src').src = CONFIG.link_musica;
        document.getElementById('track').load();

        document.getElementById('img-1').style.backgroundImage = `url('${CONFIG.foto_1}')`;
        document.getElementById('img-2').style.backgroundImage = `url('${CONFIG.foto_2}')`;
        document.getElementById('img-3').style.backgroundImage = `url('${CONFIG.foto_3}')`;
        document.getElementById('img-4').style.backgroundImage = `url('${CONFIG.foto_4}')`;
        document.getElementById('ultima-foto').src = CONFIG.foto_4;

        // LÓGICA DEL CONTADOR
        const countdownDate = new Date(CONFIG.fecha_countdown).getTime();
        const x = setInterval(function() {
            const now = new Date().getTime();
            const distance = countdownDate - now;
            const days = Math.floor(distance / (1000 * 60 * 60 * 24));
            const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((distance % (1000 * 60)) / 1000);

            document.getElementById("days").innerHTML = days < 10 ? "0"+days : days;
            document.getElementById("hours").innerHTML = hours < 10 ? "0"+hours : hours;
            document.getElementById("minutes").innerHTML = minutes < 10 ? "0"+minutes : minutes;
            document.getElementById("seconds").innerHTML = seconds < 10 ? "0"+seconds : seconds;

            if (distance < 0) {
                clearInterval(x);
                document.querySelector(".countdown-container").innerHTML = "<p style='color:var(--oro); font-weight:bold;'>¡ES HOY!</p>";
            }
        }, 1000);

        const t = document.getElementById('track');
        function controlMusica() {
            if (t.paused) { 
                t.play(); 
                document.getElementById('play-svg').style.display='none'; 
                document.getElementById('pause-svg').style.display='block'; 
            } else { 
                t.pause(); 
                document.getElementById('play-svg').style.display='block'; 
                document.getElementById('pause-svg').style.display='none'; 
            }
        }
        document.addEventListener('click', () => { if(t.paused) controlMusica(); }, {once: true});
    </script>
</body>
</html>
